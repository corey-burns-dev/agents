{
  "name": "@agents/monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/server",
      "apps/web",
      "apps/desktop/electron",
      "packages/*",
      "scripts"
    ],
    "catalog": {
      "effect": "https://pkg.pr.new/Effect-TS/effect-smol/effect@8881a9b",
      "@effect/platform-node": "https://pkg.pr.new/Effect-TS/effect-smol/@effect/platform-node@8881a9b",
      "@effect/sql-sqlite-bun": "https://pkg.pr.new/Effect-TS/effect-smol/@effect/sql-sqlite-bun@8881a9b",
      "@effect/vitest": "https://pkg.pr.new/Effect-TS/effect-smol/@effect/vitest@8881a9b",
      "@effect/language-service": "0.75.1",
      "@types/bun": "^1.3.9",
      "@types/node": "^24.10.13",
      "tsdown": "^0.20.3",
      "typescript": "^5.7.3",
      "vitest": "^4.0.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun scripts/dev-runner.ts dev",
    "dev:server": "bun scripts/dev-runner.ts dev:server",
    "dev:web": "bun scripts/dev-runner.ts dev:web",
    "dev:desktop": "bun scripts/dev-runner.ts dev:desktop",
    "start": "bun run --cwd apps/server start",
    "start:desktop": "bun run --cwd apps/desktop/electron start",
    "build": "bun run build:contracts && bun run --cwd apps/web build && bun run --cwd apps/server build && bun run --cwd apps/desktop/electron build",
    "build:desktop": "bun run build:contracts && bun run --cwd apps/web build && bun run --cwd apps/server build && bun run --cwd apps/desktop/electron build",
    "build:desktop:no-bundle": "bun run build:contracts && bun run --cwd apps/web build && bun run --cwd apps/server build && bun run --cwd apps/desktop/electron build",
    "typecheck": "bun run --cwd packages/contracts typecheck && bun run --cwd packages/shared typecheck && bun run --cwd apps/server typecheck && bun run --cwd apps/web typecheck && bun run --cwd apps/desktop/electron typecheck",
    "lint": "oxlint",
    "test": "bun run --cwd packages/contracts test && bun run --cwd packages/shared test && bun run --cwd apps/server test && bun run --cwd apps/web test && bun run --cwd apps/desktop/electron test",
    "test:desktop-smoke": "bun run --cwd apps/desktop/electron smoke-test",
    "format": "oxfmt",
    "build:contracts": "bun run --cwd packages/contracts build",
    "dist:desktop:artifact": "bun scripts/build-desktop-artifact.ts",
    "dist:desktop:linux": "bun scripts/build-desktop-artifact.ts --platform linux --target AppImage --arch x64",
    "dist:desktop:mac": "bun scripts/build-desktop-artifact.ts --platform mac --target dmg --arch arm64",
    "dist:desktop:win": "bun scripts/build-desktop-artifact.ts --platform win --target nsis --arch x64",
    "clean": "rm -rf node_modules apps/*/node_modules apps/desktop/node_modules apps/desktop/*/node_modules packages/*/node_modules apps/*/dist packages/*/dist apps/desktop/electron/dist-electron release",
    "update": "bun scripts/update-deps.ts",
    "update:check": "bun scripts/update-deps.ts --check",
    "sync:vscode-icons": "bun scripts/sync-vscode-icons.mjs",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^25.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "oxfmt": "^0.37.0",
    "oxlint": "^1.52.0",
    "simple-git-hooks": "^2.13.1",
    "vitest": "^4.0.18"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged && bun run typecheck"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,yml,yaml}": [
      "oxfmt"
    ],
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxlint"
    ]
  },
  "engines": {
    "bun": "^1.3.9",
    "node": "^24.13.1"
  },
  "packageManager": "bun@1.3.9",
  "msw": {
    "workerDirectory": [
      "apps/web/public"
    ]
  }
}
